{
  "name": "hausverwaltung",
  "version": "1.1.0",
  "description": "Hausverwaltung App",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix hausverwaltung-app --legacy-peer-deps && npm install --prefix backend",
    "build": "npm run build --prefix hausverwaltung-app",
    "start": "node backend/server.js",
    "dev:frontend": "npm run dev --prefix hausverwaltung-app",
    "dev:backend": "node --watch backend/server.js"
  }
}
